rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['userId', 'updatedAt'])
        && data.userId == request.auth.uid
        && data.updatedAt == request.time
        && (!('completedQuestions' in data) || (data.completedQuestions is list && data.completedQuestions.size() <= 200))
        && (!('failedQuestionIds' in data) || (data.failedQuestionIds is list && data.failedQuestionIds.size() <= 200))
        && (!('starMap' in data) || (data.starMap is map && data.starMap.size() <= 200));
    }

    match /users/{userId} {
      allow read: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && request.auth.uid == userId 
        && isValidUserProgress(incoming())
        && incoming().keys().hasAll(['userId', 'updatedAt', 'completedQuestions', 'failedQuestionIds', 'starMap'])
        && incoming().keys().size() == 5;

      allow update: if (
        isSignedIn()
        && isValidId(userId)
        && request.auth.uid == userId
        && isValidUserProgress(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['completedQuestions', 'failedQuestionIds', 'starMap', 'updatedAt'])
        && incoming().userId == existing().userId
      );
    }
  }
}
